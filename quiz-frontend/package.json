{
  "name": "review-game-2026",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "description": "Review Game - 2026 — Interactive Bible quiz game for church kids",
  "author": "Review Game",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "electron-builder",
    "electron:dev": "vite build && electron electron-main.cjs",
    "electron:build:win": "vite build && electron-builder --win --config electron-builder.json",
    "cap:sync": "vite build && npx cap sync",
    "cap:android": "vite build && npx cap sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@capacitor/core": "^6.0.0"
  },
  "devDependencies": {
    "electron": "^36.9.5",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.12"
  }
}
